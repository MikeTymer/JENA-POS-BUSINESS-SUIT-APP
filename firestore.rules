rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isOrgOwner(orgId) {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid ||
         get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerEmail == request.auth.token.email);
    }

    function isStaffMember(orgId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid));
    }

    function isStaff(orgId) {
      return isAuthenticated() && (isOrgOwner(orgId) || isStaffMember(orgId) || isAdmin());
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sakwamikes@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.size() < 100;
    }

    function isValidUrl(url) {
      return url is string && url.size() < 500;
    }

    function isValidEmail(email) {
      return email is string && email.size() < 100;
    }

    function isPositive(val) {
      return val is number && val >= 0;
    }

    function isValidList(val, maxSize) {
      return val is list && val.size() <= maxSize;
    }

    function isValidUser(data, userId) {
      return hasRequiredFields(['uid', 'email']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'phoneNumber', 'plan', 'termsAcceptedAt', 'notificationPreferences', 'createdAt', 'updatedAt', 'role']) &&
             userId == request.auth.uid &&
             (!('uid' in data) || data.uid == request.auth.uid) &&
             (!('email' in data) || isValidEmail(data.email)) &&
             (!('displayName' in data) || data.displayName == null || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || data.photoURL == null || isValidUrl(data.photoURL)) &&
             (!('phoneNumber' in data) || data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() < 20)) &&
             (!('plan' in data) || data.plan in ['trial', 'starter', 'business', 'enterprise']) &&
             (!('termsAcceptedAt' in data) || data.termsAcceptedAt == null || isValidDateString(data.termsAcceptedAt)) &&
             (!('notificationPreferences' in data) || data.notificationPreferences == null || data.notificationPreferences is map) &&
             (!('role' in data) || data.role == null || (data.role is string && data.role.size() < 50)) &&
             (!('createdAt' in data) || data.createdAt == null || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || data.updatedAt == null || isValidDateString(data.updatedAt));
    }

    function isValidOrganization(data) {
      return hasRequiredFields(['name', 'ownerUid', 'plan']) &&
             hasOnlyAllowedFields(['id', 'name', 'ownerUid', 'ownerEmail', 'country', 'currency', 'address', 'uprsRegistrationNumber', 'logoUrl', 'plan', 'subscriptionStatus', 'createdAt', 'updatedAt', 'expiresAt', 'isPaid', 'trialExpiresAt', 'referredBy', 'businessType']) &&
             data.id is string && data.id.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerUid is string && data.ownerUid.size() < 100 &&
             (!('country' in data) || data.country == null || (data.country is string && data.country.size() < 100)) &&
             (!('currency' in data) || data.currency == null || (data.currency is string && data.currency.size() < 10)) &&
             (!('address' in data) || data.address == null || (data.address is string && data.address.size() < 500)) &&
             (!('uprsRegistrationNumber' in data) || data.uprsRegistrationNumber == null || (data.uprsRegistrationNumber is string && data.uprsRegistrationNumber.size() < 50)) &&
             (!('logoUrl' in data) || data.logoUrl == null || isValidUrl(data.logoUrl)) &&
             (!('businessType' in data) || data.businessType == null || (data.businessType is string && data.businessType.size() < 50)) &&
             data.plan in ['trial', 'starter', 'business', 'enterprise'] &&
             data.subscriptionStatus is string && data.subscriptionStatus.size() < 50 &&
             (!('createdAt' in data) || data.createdAt == null || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || data.updatedAt == null || isValidDateString(data.updatedAt)) &&
             (!('expiresAt' in data) || data.expiresAt == null || isValidDateString(data.expiresAt)) &&
             (!('isPaid' in data) || data.isPaid == null || data.isPaid is bool) &&
             (!('trialExpiresAt' in data) || data.trialExpiresAt == null || isValidDateString(data.trialExpiresAt)) &&
             (!('referredBy' in data) || data.referredBy == null || (data.referredBy is string && data.referredBy.size() < 50));
    }

    function isValidInventoryItem(data) {
      return hasRequiredFields(['name', 'quantity', 'price', 'cost']) &&
             hasOnlyAllowedFields(['id', 'name', 'sku', 'category', 'price', 'cost', 'quantity', 'minStock', 'unit', 'description', 'imageUrl', 'dosageForm', 'strength', 'manufacturer', 'expiryDate', 'batchNumber', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.quantity is number &&
             isPositive(data.price) &&
             (!('cost' in data) || data.cost == null || isPositive(data.cost)) &&
             (!('sku' in data) || data.sku == null || (data.sku is string && data.sku.size() < 50)) &&
             (!('category' in data) || data.category == null || (data.category is string && data.category.size() < 50)) &&
             (!('minStock' in data) || data.minStock == null || isPositive(data.minStock)) &&
             (!('unit' in data) || data.unit == null || (data.unit is string && data.unit.size() < 20)) &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() < 500)) &&
             (!('imageUrl' in data) || data.imageUrl == null || isValidUrl(data.imageUrl)) &&
             (!('dosageForm' in data) || data.dosageForm == null || (data.dosageForm is string && data.dosageForm.size() < 50)) &&
             (!('strength' in data) || data.strength == null || (data.strength is string && data.strength.size() < 50)) &&
             (!('manufacturer' in data) || data.manufacturer == null || (data.manufacturer is string && data.manufacturer.size() < 100)) &&
             (!('expiryDate' in data) || data.expiryDate == null || isValidDateString(data.expiryDate) || data.expiryDate == "") &&
             (!('batchNumber' in data) || data.batchNumber == null || (data.batchNumber is string && data.batchNumber.size() < 50)) &&
             (!('createdAt' in data) || data.createdAt == null || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || data.updatedAt == null || isValidDateString(data.updatedAt));
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['type', 'amount', 'date']) &&
             hasOnlyAllowedFields(['type', 'amount', 'category', 'description', 'date', 'receiptId', 'items', 'paymentMethod', 'phoneNumber', 'customerId', 'dueDate', 'createdAt', 'updatedAt']) &&
             data.type in ['income', 'expense'] &&
             isPositive(data.amount) &&
             (!('category' in data) || data.category == null || (data.category is string && data.category.size() < 50)) &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() < 2000)) &&
             isValidDateString(data.date) &&
             (!('receiptId' in data) || data.receiptId == null || (data.receiptId is string && data.receiptId.size() < 50)) &&
             (!('items' in data) || data.items == null || isValidList(data.items, 100)) &&
             (!('paymentMethod' in data) || data.paymentMethod == null || (data.paymentMethod is string && data.paymentMethod.size() < 50)) &&
             (!('phoneNumber' in data) || data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() < 20)) &&
             (!('customerId' in data) || data.customerId == null || (data.customerId is string && data.customerId.size() < 50)) &&
             (!('dueDate' in data) || data.dueDate == null || isValidDateString(data.dueDate)) &&
             (!('createdAt' in data) || data.createdAt == null || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || data.updatedAt == null || isValidDateString(data.updatedAt));
    }

    function isValidReceipt(data) {
      return hasRequiredFields(['items', 'total', 'date']) &&
             hasOnlyAllowedFields(['transactionId', 'items', 'subtotal', 'tax', 'total', 'amountPaid', 'balance', 'amountOwing', 'customerTotalDebt', 'paymentMethod', 'date', 'cashierName', 'customerId', 'customerName', 'dueDate', 'patientName', 'prescriptionNumber', 'doctorName', 'createdAt', 'updatedAt']) &&
             isValidList(data.items, 100) &&
             isPositive(data.total) &&
             (!('transactionId' in data) || data.transactionId == null || (data.transactionId is string && data.transactionId.size() < 50)) &&
             (!('subtotal' in data) || data.subtotal == null || isPositive(data.subtotal)) &&
             (!('tax' in data) || data.tax == null || isPositive(data.tax)) &&
             (!('amountPaid' in data) || data.amountPaid == null || isPositive(data.amountPaid)) &&
             (!('balance' in data) || data.balance == null || isPositive(data.balance)) &&
             (!('amountOwing' in data) || data.amountOwing == null || isPositive(data.amountOwing)) &&
             (!('customerTotalDebt' in data) || data.customerTotalDebt == null || isPositive(data.customerTotalDebt)) &&
             (!('paymentMethod' in data) || data.paymentMethod == null || (data.paymentMethod is string && data.paymentMethod.size() < 50)) &&
             (!('date' in data) || data.date == null || isValidDateString(data.date)) &&
             (!('cashierName' in data) || data.cashierName == null || (data.cashierName is string && data.cashierName.size() < 200)) &&
             (!('customerId' in data) || data.customerId == null || (data.customerId is string && data.customerId.size() < 50)) &&
             (!('customerName' in data) || data.customerName == null || (data.customerName is string && data.customerName.size() < 100)) &&
             (!('dueDate' in data) || data.dueDate == null || isValidDateString(data.dueDate)) &&
             (!('patientName' in data) || data.patientName == null || (data.patientName is string && data.patientName.size() < 100)) &&
             (!('prescriptionNumber' in data) || data.prescriptionNumber == null || (data.prescriptionNumber is string && data.prescriptionNumber.size() < 100)) &&
             (!('doctorName' in data) || data.doctorName == null || (data.doctorName is string && data.doctorName.size() < 100)) &&
             (!('createdAt' in data) || data.createdAt == null || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || data.updatedAt == null || isValidDateString(data.updatedAt));
    }

    function isValidDamageRecord(data) {
      return hasRequiredFields(['itemId', 'itemName', 'quantity', 'date']) &&
             hasOnlyAllowedFields(['itemId', 'itemName', 'quantity', 'reason', 'imageUrl', 'date', 'reportedBy', 'cost', 'createdAt', 'updatedAt']) &&
             data.itemId is string && data.itemId.size() < 100 &&
             data.itemName is string && data.itemName.size() < 100 &&
             isPositive(data.quantity) && data.quantity > 0 &&
             isValidDateString(data.date) &&
             (!('reason' in data) || (data.reason is string && data.reason.size() < 500)) &&
             (!('imageUrl' in data) || isValidUrl(data.imageUrl)) &&
             (!('reportedBy' in data) || (data.reportedBy is string && data.reportedBy.size() < 100)) &&
             (!('cost' in data) || isPositive(data.cost)) &&
             (!('createdAt' in data) || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || isValidDateString(data.updatedAt));
    }

    function isValidStaffMember(data) {
      return hasRequiredFields(['email', 'role']) &&
             hasOnlyAllowedFields(['id', 'uid', 'email', 'displayName', 'role', 'addedAt', 'createdAt', 'updatedAt']) &&
             isValidEmail(data.email) && 
             data.role in ['director', 'manager', 'cashier'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('uid' in data) || (data.uid is string && data.uid.size() < 100)) &&
             (!('addedAt' in data) || isValidDateString(data.addedAt)) &&
             (!('createdAt' in data) || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || isValidDateString(data.updatedAt));
    }

    function isValidNotification(data) {
      return hasRequiredFields(['type', 'title', 'message', 'timestamp']) &&
             hasOnlyAllowedFields(['type', 'title', 'message', 'timestamp', 'read', 'metadata', 'createdAt', 'updatedAt']) &&
             data.type in ['sale', 'login', 'logout', 'system', 'inventory', 'damage', 'expense'] &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 2000 &&
             isValidDateString(data.timestamp) &&
             (!('read' in data) || data.read is bool) &&
             (!('metadata' in data) || data.metadata is map) &&
             (!('createdAt' in data) || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || isValidDateString(data.updatedAt));
    }

    function isValidCustomer(data) {
      return hasRequiredFields(['name', 'totalDebt']) &&
             hasOnlyAllowedFields(['id', 'name', 'phone', 'email', 'address', 'totalDebt', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             isPositive(data.totalDebt) &&
             (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() < 20)) &&
             (!('email' in data) || data.email == null || isValidEmail(data.email)) &&
             (!('address' in data) || data.address == null || (data.address is string && data.address.size() < 500)) &&
             (!('createdAt' in data) || data.createdAt == null || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || data.updatedAt == null || isValidDateString(data.updatedAt));
    }

    function isValidDebtPayment(data) {
      return hasRequiredFields(['customerId', 'amount', 'method', 'timestamp']) &&
             hasOnlyAllowedFields(['id', 'customerId', 'amount', 'method', 'timestamp', 'notes', 'createdAt', 'updatedAt']) &&
             data.customerId is string && data.customerId.size() < 100 &&
             isPositive(data.amount) && data.amount > 0 &&
             data.method in ['cash', 'momo', 'card', 'Cash', 'Card', 'MTN Mobile Money'] &&
             isValidDateString(data.timestamp) &&
             (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() < 500)) &&
             (!('createdAt' in data) || data.createdAt == null || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || data.updatedAt == null || isValidDateString(data.updatedAt));
    }

    function isValidMembership(data) {
      return hasRequiredFields(['orgId', 'role']) &&
             hasOnlyAllowedFields(['id', 'userId', 'orgId', 'role', 'orgName', 'email', 'createdAt', 'updatedAt']) &&
             data.orgId is string && data.orgId.size() < 100 &&
             data.role in ['director', 'manager', 'cashier'] &&
             (!('userId' in data) || data.userId == null || (data.userId is string && data.userId.size() < 100)) &&
             (!('orgName' in data) || (data.orgName is string && data.orgName.size() < 100)) &&
             (!('email' in data) || isValidEmail(data.email)) &&
             (!('createdAt' in data) || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || isValidDateString(data.updatedAt));
    }

    function isValidAffiliate(data) {
      return hasRequiredFields(['uid', 'affiliateCode', 'status']) &&
             hasOnlyAllowedFields(['uid', 'affiliateCode', 'status', 'totalEarnings', 'unpaidEarnings', 'totalClicks', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.uid.size() < 100 &&
             data.affiliateCode is string && data.affiliateCode.size() > 0 && data.affiliateCode.size() < 50 &&
             data.status in ['active', 'pending', 'suspended'] &&
             (!('totalEarnings' in data) || isPositive(data.totalEarnings)) &&
             (!('unpaidEarnings' in data) || isPositive(data.unpaidEarnings)) &&
             (!('totalClicks' in data) || isPositive(data.totalClicks)) &&
             (!('createdAt' in data) || isValidDateString(data.createdAt)) &&
             (!('updatedAt' in data) || isValidDateString(data.updatedAt));
    }

    function isValidReferral(data) {
      return hasRequiredFields(['affiliateUid', 'referredOrgId', 'status']) &&
             hasOnlyAllowedFields(['id', 'affiliateUid', 'referredOrgId', 'referredOrgName', 'referredUid', 'referredEmail', 'status', 'amountEarned', 'createdAt', 'paidAt', 'updatedAt']) &&
             data.affiliateUid is string && data.affiliateUid.size() < 100 &&
             data.referredOrgId is string && data.referredOrgId.size() < 100 &&
             (!('referredOrgName' in data) || (data.referredOrgName is string && data.referredOrgName.size() < 100)) &&
             (!('referredUid' in data) || (data.referredUid is string && data.referredUid.size() < 100)) &&
             (!('referredEmail' in data) || isValidEmail(data.referredEmail)) &&
             data.status in ['registered', 'trial_active', 'paid', 'completed', 'expired'] &&
             (!('amountEarned' in data) || isPositive(data.amountEarned)) &&
             (!('createdAt' in data) || isValidDateString(data.createdAt)) &&
             (!('paidAt' in data) || isValidDateString(data.paidAt) || data.paidAt == null) &&
             (!('updatedAt' in data) || isValidDateString(data.updatedAt));
    }

    function isValidPayment(data) {
      return hasRequiredFields(['orgId', 'userId', 'amount', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'orgId', 'userId', 'amount', 'currency', 'status', 'method', 'plan', 'phoneNumber', 'error', 'createdAt', 'updatedAt']) &&
             data.orgId is string && data.orgId.size() < 100 &&
             data.userId is string && data.userId.size() < 100 &&
             isPositive(data.amount) && data.amount > 0 &&
             data.status in ['pending', 'completed', 'failed'] &&
             (!('method' in data) || (data.method is string && data.method.size() < 50)) &&
             (!('plan' in data) || (data.plan is string && data.plan.size() < 50)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() < 20) || data.phoneNumber == null) &&
             (!('error' in data) || (data.error is string && data.error.size() < 500)) &&
             isValidDateString(data.createdAt) &&
             (!('updatedAt' in data) || isValidDateString(data.updatedAt));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data, userId) && 
                      (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(userId) && isValidUser(request.resource.data, userId) && 
                      request.resource.data.createdAt == resource.data.createdAt &&
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
    }

    match /organizations/{orgId} {
      allow read: if isStaff(orgId);
      allow create: if isAuthenticated() && isValidOrganization(request.resource.data) && request.resource.data.ownerUid == request.auth.uid;
      allow update: if (isOrgOwner(orgId) || isAdmin()) && isValidOrganization(request.resource.data) && 
                      request.resource.data.ownerUid == resource.data.ownerUid &&
                      request.resource.data.id == resource.data.id &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOrgOwner(orgId) || isAdmin();

      match /inventory/{itemId} {
        allow read: if isStaff(orgId);
        allow create: if isStaff(orgId) && isValidInventoryItem(request.resource.data);
        allow update: if isStaff(orgId) && 
                        (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
        allow delete: if isOrgOwner(orgId);
      }

      match /transactions/{txId} {
        allow read: if isStaff(orgId);
        allow create: if isStaff(orgId) && isValidTransaction(request.resource.data);
        allow update: if isStaff(orgId) && isValidTransaction(request.resource.data) && 
                        request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOrgOwner(orgId);
      }

      match /receipts/{receiptId} {
        allow read: if isStaff(orgId);
        allow create: if isStaff(orgId) && isValidReceipt(request.resource.data);
        allow delete: if isOrgOwner(orgId);
      }

      match /damages/{damageId} {
        allow read: if isStaff(orgId);
        allow create: if isStaff(orgId) && isValidDamageRecord(request.resource.data);
        allow delete: if isOrgOwner(orgId);
      }

      match /staff/{staffId} {
        allow read: if isStaff(orgId);
        allow create: if (isOrgOwner(orgId) || isAdmin() || request.auth.uid == staffId) && isValidStaffMember(request.resource.data);
        allow update: if (isOrgOwner(orgId) || isAdmin() || request.auth.uid == staffId) && isValidStaffMember(request.resource.data);
        allow delete: if (isOrgOwner(orgId) || isAdmin());
      }

      match /notifications/{notificationId} {
        allow read: if isStaff(orgId);
        allow create: if isStaff(orgId);
        allow update: if isStaff(orgId) && isValidNotification(request.resource.data);
        allow delete: if isOrgOwner(orgId);
      }

      match /customers/{customerId} {
        allow read: if isStaff(orgId);
        allow create: if isStaff(orgId) && isValidCustomer(request.resource.data);
        allow update: if isStaff(orgId) && 
                        (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
        allow delete: if isOrgOwner(orgId);

        match /payments/{paymentId} {
          allow read: if isStaff(orgId);
          allow create: if isStaff(orgId) && isValidDebtPayment(request.resource.data);
        }
      }
    }

    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.email == request.auth.token.email || isAdmin() || isOrgOwner(resource.data.orgId));
      allow create: if isAuthenticated() && isValidMembership(request.resource.data);
      allow update: if isAuthenticated() && isValidMembership(request.resource.data) && (resource.data.userId == request.auth.uid || resource.data.email == request.auth.token.email || isAdmin() || isOrgOwner(resource.data.orgId));
      allow delete: if isAdmin() || isOrgOwner(resource.data.orgId);
    }

    match /affiliates/{affiliateUid} {
      allow read: if isOwner(affiliateUid);
      allow create: if isOwner(affiliateUid) && isValidAffiliate(request.resource.data);
      allow update: if isOwner(affiliateUid) && isValidAffiliate(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (resource.data.affiliateUid == request.auth.uid || resource.data.referredUid == request.auth.uid);
      allow create: if isAuthenticated() && isValidReferral(request.resource.data);
      allow update: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidPayment(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
