rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "sakwamikes@gmail.com";
    }

    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    function isOrgOwner(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
      );
    }

    function isStaffMember(orgId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid));
    }

    function isStaff(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() || isOrgOwner(orgId) || isStaffMember(orgId)
      );
    }

    function hasRole(orgId, roles) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        isOrgOwner(orgId) || 
        (isStaffMember(orgId) && get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data.role in roles)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'phoneNumber', 'plan', 'termsAcceptedAt', 'notificationPreferences', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.email is string &&
             data.uid == request.auth.uid &&
             (!('plan' in data) || data.plan in ['trial', 'starter', 'business', 'enterprise']) &&
             (!('termsAcceptedAt' in data) || data.termsAcceptedAt is string) &&
             (!('notificationPreferences' in data) || data.notificationPreferences is map);
    }

    function isValidOrganization(data) {
      return hasOnlyAllowedFields(['id', 'name', 'ownerUid', 'country', 'currency', 'address', 'uprsRegistrationNumber', 'logoUrl', 'plan', 'subscriptionStatus', 'createdAt', 'updatedAt', 'expiresAt', 'isPaid', 'trialExpiresAt', 'referredBy']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerUid is string &&
             (!('country' in data) || data.country is string) &&
             (!('currency' in data) || data.currency is string) &&
             (!('address' in data) || data.address is string) &&
             (!('uprsRegistrationNumber' in data) || data.uprsRegistrationNumber is string) &&
             (!('logoUrl' in data) || data.logoUrl is string) &&
             data.plan in ['trial', 'starter', 'business', 'enterprise'] &&
             data.subscriptionStatus is string &&
             data.createdAt is string &&
             (!('updatedAt' in data) || data.updatedAt is string) &&
             (!('expiresAt' in data) || data.expiresAt is string || data.expiresAt == null) &&
             (!('isPaid' in data) || data.isPaid is bool) &&
             (!('trialExpiresAt' in data) || data.trialExpiresAt is string) &&
             (!('referredBy' in data) || data.referredBy is string);
    }

    function isValidAffiliate(data) {
      return hasOnlyAllowedFields(['uid', 'affiliateCode', 'status', 'totalEarnings', 'unpaidEarnings', 'totalClicks', 'createdAt', 'updatedAt']) &&
             data.uid is string &&
             data.affiliateCode is string && data.affiliateCode.size() > 0 &&
             data.status in ['active', 'pending', 'suspended'] &&
             (!('totalEarnings' in data) || data.totalEarnings is number) &&
             (!('unpaidEarnings' in data) || data.unpaidEarnings is number) &&
             (!('totalClicks' in data) || data.totalClicks is number);
    }

    function isValidReferral(data) {
      return hasOnlyAllowedFields(['id', 'affiliateUid', 'referredOrgId', 'referredUid', 'status', 'amountEarned', 'createdAt', 'paidAt', 'updatedAt']) &&
             data.affiliateUid is string &&
             data.referredOrgId is string &&
             data.status in ['registered', 'paid', 'completed'];
    }

    function isValidPayment(data) {
      return hasOnlyAllowedFields(['id', 'orgId', 'userId', 'amount', 'currency', 'status', 'method', 'plan', 'phoneNumber', 'error', 'createdAt', 'updatedAt']) &&
             data.orgId is string && data.userId is string &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'completed', 'failed'] &&
             (!('method' in data) || data.method is string) &&
             (!('plan' in data) || data.plan is string) &&
             (!('phoneNumber' in data) || data.phoneNumber is string || data.phoneNumber == null) &&
             (!('error' in data) || data.error is string);
    }

    function isValidInventoryItem(data) {
      return hasOnlyAllowedFields(['name', 'sku', 'quantity', 'price', 'cost', 'category', 'imageUrl', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.quantity is number && data.price is number && data.cost is number &&
             (!('imageUrl' in data) || data.imageUrl is string);
    }

    function isValidDamageRecord(data) {
      return hasOnlyAllowedFields(['itemId', 'itemName', 'quantity', 'reason', 'imageUrl', 'date', 'reportedBy', 'cost', 'createdAt', 'updatedAt']) &&
             data.itemId is string && data.itemName is string &&
             data.quantity is number && data.quantity > 0 &&
             data.date is string &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('cost' in data) || data.cost is number);
    }

    function isValidTransaction(data) {
      return hasOnlyAllowedFields(['type', 'amount', 'category', 'description', 'date', 'receiptId', 'items', 'paymentMethod', 'phoneNumber', 'createdAt', 'updatedAt']) &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount >= 0 &&
             (!('receiptId' in data) || data.receiptId is string) &&
             (!('items' in data) || data.items is list) &&
             (!('paymentMethod' in data) || data.paymentMethod is string) &&
             (!('phoneNumber' in data) || data.phoneNumber is string);
    }

    function isValidReceipt(data) {
      return hasOnlyAllowedFields(['transactionId', 'items', 'subtotal', 'tax', 'total', 'amountPaid', 'balance', 'paymentMethod', 'date', 'cashierName', 'createdAt', 'updatedAt']) &&
             data.items is list &&
             data.total is number && data.total >= 0 &&
             (!('amountPaid' in data) || data.amountPaid is number) &&
             (!('balance' in data) || data.balance is number);
    }

    function isValidStaffMember(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'email', 'displayName', 'role', 'addedAt', 'updatedAt']) &&
             data.email is string && data.role in ['admin', 'manager', 'cashier'];
    }

    function isValidNotification(data) {
      return hasOnlyAllowedFields(['type', 'title', 'message', 'timestamp', 'read', 'metadata', 'createdAt', 'updatedAt']) &&
             data.type in ['sale', 'login', 'logout', 'system', 'inventory', 'damage', 'expense'] &&
             data.title is string && data.message is string &&
             data.timestamp is string &&
             (!('read' in data) || data.read is bool);
    }

    function isValidMembership(data) {
      return hasOnlyAllowedFields(['userId', 'orgId', 'role', 'orgName', 'email', 'updatedAt']) &&
             data.orgId is string && data.role is string;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.userId == request.auth.uid || 
        resource.data.email == request.auth.token.email
      );
      allow create: if (isSuperAdmin() || hasRole(request.resource.data.orgId, ['admin'])) && isValidMembership(request.resource.data);
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.email == request.auth.token.email && request.resource.data.userId == request.auth.uid) ||
        hasRole(resource.data.orgId, ['admin'])
      );
      allow delete: if isSuperAdmin() || hasRole(resource.data.orgId, ['admin']);
    }

    match /organizations/{orgId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.ownerUid == request.auth.uid) ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid))
      );
      allow create: if isAuthenticated() && 
                    (isSuperAdmin() || (isValidOrganization(request.resource.data) && request.resource.data.ownerUid == request.auth.uid));
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.ownerUid == request.auth.uid) ||
        (isStaffMember(orgId) && get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data.role == 'admin')
      ) && isValidOrganization(request.resource.data) && 
      (isSuperAdmin() || (
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.createdAt == resource.data.createdAt
      ));
      allow delete: if isAuthenticated() && (isSuperAdmin() || (resource != null && resource.data.ownerUid == request.auth.uid));
    }

    match /organizations/{orgId}/inventory/{itemId} {
      allow read: if isStaff(orgId);
      allow create: if hasRole(orgId, ['admin', 'manager']) && isValidInventoryItem(request.resource.data);
      allow update: if isStaff(orgId);
      allow delete: if hasRole(orgId, ['admin']);
    }

    match /organizations/{orgId}/transactions/{txId} {
      allow read: if isStaff(orgId);
      allow create: if isStaff(orgId);
      allow update: if isStaff(orgId);
      allow delete: if hasRole(orgId, ['admin']);
    }

    match /organizations/{orgId}/receipts/{receiptId} {
      allow read: if isStaff(orgId);
      allow create: if isStaff(orgId);
      allow delete: if hasRole(orgId, ['admin']);
    }

    match /organizations/{orgId}/damages/{damageId} {
      allow read: if isStaff(orgId);
      allow create: if hasRole(orgId, ['admin', 'manager', 'cashier']) && isValidDamageRecord(request.resource.data);
      allow delete: if hasRole(orgId, ['admin']);
    }

    match /organizations/{orgId}/staff/{staffId} {
      allow read: if isStaff(orgId);
      allow create: if hasRole(orgId, ['admin']) && isValidStaffMember(request.resource.data);
      allow update: if hasRole(orgId, ['admin']) && isValidStaffMember(request.resource.data);
      allow delete: if hasRole(orgId, ['admin']);
    }

    match /organizations/{orgId}/notifications/{notificationId} {
      allow read: if isStaff(orgId);
      allow create: if isStaff(orgId);
      allow update: if hasRole(orgId, ['admin', 'manager']) && isValidNotification(request.resource.data);
      allow delete: if hasRole(orgId, ['admin']);
    }

    match /affiliates/{affiliateUid} {
      allow read: if isOwner(affiliateUid);
      allow create: if isOwner(affiliateUid) && isValidAffiliate(request.resource.data);
      allow update: if (isAuthenticated() && isOwner(affiliateUid) && isValidAffiliate(request.resource.data)) || 
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalClicks']) && 
                       request.resource.data.totalClicks == resource.data.totalClicks + 1);
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource.data.affiliateUid == request.auth.uid);
      allow create: if isAuthenticated(); // System creates this upon registration
      allow update: if isSuperAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidPayment(request.resource.data) && (isSuperAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isSuperAdmin();
    }
  }
}
